# MedSecure - Comprehensive .gitignore

# ===========================
# SENSITIVE FILES (NEVER COMMIT)
# ===========================
# Environment variables
.env
.env.local
.env.production
.env.*.local

# Database files
*.sqlite3
*.db
db.sqlite3
*.sql
dumps/

# Secret keys and credentials
secrets.json
*.key
*.pem
*.p12
*.pfx

# ===========================
# Python / Django
# ===========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
.venv2/
venv3.11.9/
ENV/
env/
env.bak/
venv.bak/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
/static/

# Django migrations (optional - comment out to track migrations)
# */migrations/*.py
# */migrations/*.pyc
# !*/migrations/__init__.py

# ===========================
# Node / Frontend
# ===========================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
dist-ssr/
build/
*.local

# ===========================
# IDEs and Editors
# ===========================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vs/

# ===========================
# OS Generated Files
# ===========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===========================
# Testing
# ===========================
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage/
*.cover
.hypothesis/

# ===========================
# Logs
# ===========================
logs/
*.log
log/

# ===========================
# Temporary Files
# ===========================
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# ===========================
# Backups
# ===========================
*.bak
*.backup
backup/
backups/

# ===========================
# Documentation Build
# ===========================
docs/_build/
site/

# ===========================
# Package Files
# ===========================
*.egg
*.egg-info/
dist/
build/
wheels/
pip-wheel-metadata/

# ===========================
# Project Specific
# ===========================
# Duplicate/scratch folders
scratch/
old/
archive/

# Uploaded media files (if sensitive)
# media/uploads/

# Local configuration
config.local.py
settings.local.py

